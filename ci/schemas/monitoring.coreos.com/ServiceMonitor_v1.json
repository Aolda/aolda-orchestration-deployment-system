{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "monitoring.coreos.com/v1" },
    "kind": { "const": "ServiceMonitor" },
    "metadata": {
      "type": "object",
      "required": ["name", "namespace"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string", "minLength": 1 },
        "labels": { "type": "object" }
      },
      "additionalProperties": true
    },
    "spec": {
      "type": "object",
      "required": ["namespaceSelector", "selector", "endpoints"],
      "properties": {
        "namespaceSelector": {
          "type": "object",
          "required": ["matchNames"],
          "properties": {
            "matchNames": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "additionalProperties": true
        },
        "selector": {
          "type": "object",
          "required": ["matchLabels"],
          "properties": {
            "matchLabels": { "type": "object" }
          },
          "additionalProperties": true
        },
        "endpoints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["port", "path", "interval"],
            "properties": {
              "port": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 },
              "interval": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
