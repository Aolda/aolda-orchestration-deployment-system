{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "argoproj.io/v1alpha1" },
    "kind": { "const": "Rollout" },
    "metadata": {
      "type": "object",
      "required": ["name", "namespace"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "spec": {
      "type": "object",
      "required": ["replicas", "selector", "template", "strategy"],
      "properties": {
        "replicas": { "type": "integer", "minimum": 1 },
        "selector": {
          "type": "object",
          "required": ["matchLabels"],
          "properties": {
            "matchLabels": { "type": "object" }
          },
          "additionalProperties": true
        },
        "template": { "type": "object" },
        "strategy": {
          "type": "object",
          "required": ["canary"],
          "properties": {
            "canary": {
              "type": "object",
              "required": ["stableService", "canaryService", "trafficRouting", "steps"],
              "properties": {
                "stableService": { "type": "string", "minLength": 1 },
                "canaryService": { "type": "string", "minLength": 1 },
                "trafficRouting": {
                  "type": "object",
                  "required": ["istio"],
                  "properties": {
                    "istio": {
                      "type": "object",
                      "required": ["virtualService"],
                      "properties": {
                        "virtualService": {
                          "type": "object",
                          "required": ["name", "routes"],
                          "properties": {
                            "name": { "type": "string", "minLength": 1 },
                            "routes": {
                              "type": "array",
                              "minItems": 1,
                              "items": { "type": "string", "minLength": 1 }
                            }
                          },
                          "additionalProperties": true
                        }
                      },
                      "additionalProperties": true
                    }
                  },
                  "additionalProperties": true
                },
                "steps": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "anyOf": [
                      {
                        "required": ["setWeight"],
                        "properties": {
                          "setWeight": { "type": "integer", "minimum": 0, "maximum": 100 }
                        }
                      },
                      {
                        "required": ["pause"],
                        "properties": {
                          "pause": { "type": "object" }
                        }
                      }
                    ],
                    "additionalProperties": true
                  }
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
