{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "networking.istio.io/v1" },
    "kind": { "const": "VirtualService" },
    "metadata": {
      "type": "object",
      "required": ["name", "namespace"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "spec": {
      "type": "object",
      "required": ["hosts", "http"],
      "properties": {
        "hosts": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "http": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["route"],
            "properties": {
              "name": { "type": "string" },
              "route": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["destination"],
                  "properties": {
                    "destination": {
                      "type": "object",
                      "required": ["host"],
                      "properties": {
                        "host": { "type": "string", "minLength": 1 },
                        "subset": { "type": "string" }
                      },
                      "additionalProperties": true
                    },
                    "weight": { "type": "integer", "minimum": 0, "maximum": 100 }
                  },
                  "additionalProperties": true
                }
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
