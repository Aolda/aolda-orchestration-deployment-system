{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "external-secrets.io/v1beta1" },
    "kind": { "const": "ExternalSecret" },
    "metadata": {
      "type": "object",
      "required": ["name", "namespace"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string", "minLength": 1 },
        "annotations": { "type": "object" }
      },
      "additionalProperties": true
    },
    "spec": {
      "type": "object",
      "required": ["refreshInterval", "secretStoreRef", "target", "dataFrom"],
      "properties": {
        "refreshInterval": { "type": "string", "minLength": 1 },
        "secretStoreRef": {
          "type": "object",
          "required": ["name", "kind"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "kind": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": true
        },
        "target": {
          "type": "object",
          "required": ["name", "creationPolicy"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "creationPolicy": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": true
        },
        "dataFrom": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["extract"],
            "properties": {
              "extract": {
                "type": "object",
                "required": ["key"],
                "properties": {
                  "key": { "type": "string", "minLength": 1 }
                },
                "additionalProperties": true
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
