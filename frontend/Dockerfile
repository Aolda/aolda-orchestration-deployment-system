FROM node:22-alpine AS build

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

ARG VITE_API_BASE_URL=/api
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
ARG VITE_AODS_AUTH_MODE=header
ENV VITE_AODS_AUTH_MODE=${VITE_AODS_AUTH_MODE}
ARG VITE_AODS_OIDC_ISSUER_URL=
ENV VITE_AODS_OIDC_ISSUER_URL=${VITE_AODS_OIDC_ISSUER_URL}
ARG VITE_AODS_OIDC_CLIENT_ID=
ENV VITE_AODS_OIDC_CLIENT_ID=${VITE_AODS_OIDC_CLIENT_ID}
ARG VITE_AODS_OIDC_REDIRECT_URI=
ENV VITE_AODS_OIDC_REDIRECT_URI=${VITE_AODS_OIDC_REDIRECT_URI}
ARG VITE_AODS_OIDC_SCOPE="openid profile email"
ENV VITE_AODS_OIDC_SCOPE=${VITE_AODS_OIDC_SCOPE}
ARG VITE_AODS_ALLOW_EMERGENCY_LOGIN=false
ENV VITE_AODS_ALLOW_EMERGENCY_LOGIN=${VITE_AODS_ALLOW_EMERGENCY_LOGIN}
ARG VITE_AODS_PLATFORM_ADMIN_AUTHORITIES=aods:platform:admin
ENV VITE_AODS_PLATFORM_ADMIN_AUTHORITIES=${VITE_AODS_PLATFORM_ADMIN_AUTHORITIES}

COPY . .
RUN npm run build

FROM nginx:1.27-alpine

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
